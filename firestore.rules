rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fungsi bantuan untuk cek role
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return request.auth != null && getUserData().role == 'admin';
    }

    function isAsman() {
      return request.auth != null && getUserData().role == 'asman';
    }

    function isKoordinatorDriver() {
      return request.auth != null && getUserData().role == 'koordinator_driver';
    }

    function isStaffUmum() {
      return request.auth != null && getUserData().role == 'staff_umum';
    }
    
    function isViewOnly() {
      return request.auth != null && getUserData().role == 'view';
    }

    // Koleksi Users: Hanya Admin atau diri sendiri yang bisa baca/tulis lengkap
    match /users/{userId} {
      allow read, write: if isAdmin() || request.auth.uid == userId;
    }

    // Koleksi Rooms: Semua bisa baca, hanya Admin yang bisa tulis
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Koleksi Bookings: Semua bisa baca (untuk kalender), tapi update/delete sangat dibatasi
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && !isViewOnly();
      
      // Update/Delete: Admin & Asman bisa, Staff Umum bisa (untuk kelola konsumsi), User hanya bisa miliknya sendiri
      allow update: if isAdmin() || isAsman() || isStaffUmum() || (
        request.auth.uid == resource.data.userId && 
        !isViewOnly()
      );
      allow delete: if isAdmin() || (request.auth.uid == resource.data.userId && !isViewOnly());
    }

    // Koleksi Vehicle Bookings: PRIVASI KETAT
    // Hanya Pemilik, Koordinator Driver, Staff Umum, Asman Umum, atau Admin yang bisa baca/tulis
    match /vehicle_bookings/{bookingId} {
      allow read: if request.auth != null && (
        isAdmin() || isKoordinatorDriver() || isStaffUmum() || isAsman() || request.auth.uid == resource.data.userId
      );
      allow create: if request.auth != null && !isViewOnly();
      allow update: if request.auth != null && (
        isAdmin() || isKoordinatorDriver() || isAsman() || (request.auth.uid == resource.data.userId && !isViewOnly())
      );
      allow delete: if request.auth != null && (
        isAdmin() || isKoordinatorDriver() || isAsman() || (request.auth.uid == resource.data.userId && !isViewOnly())
      );
    }

    // Koleksi Item Requests: PRIVASI KETAT
    match /item_requests/{requestId} {
      allow read: if request.auth != null && (
        isAdmin() || isAsman() || isStaffUmum() || request.auth.uid == resource.data.userId
      );
      allow create: if request.auth != null && !isViewOnly();
      allow update: if request.auth != null && (
        isAdmin() || isAsman() || isStaffUmum() || (
          request.auth.uid == resource.data.userId && resource.data.status == 'pending'
        )
      );
      allow delete: if request.auth != null && (
        isAdmin() || (request.auth.uid == resource.data.userId && resource.data.status == 'pending')
      );
    }
  }
}
