rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fungsi bantuan untuk cek role (Safe Version)
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }
    
    function isAdmin() {
      let data = getUserData();
      return request.auth != null && data != null && data.role == 'admin';
    }

    function isAsman() {
      let data = getUserData();
      return request.auth != null && data != null && data.role == 'asman';
    }

    function isKoordinatorDriver() {
      let data = getUserData();
      return request.auth != null && data != null && data.role == 'koordinator_driver';
    }

    function isStaffUmum() {
      let data = getUserData();
      return request.auth != null && data != null && data.role == 'staff_umum';
    }
    
    function isDriverRole() {
      let data = getUserData();
      return request.auth != null && data != null && data.role == 'driver';
    }
    
    function isViewOnly() {
      return request.auth != null && getUserData().role == 'view';
    }

    // Koleksi Users: Hanya Admin atau diri sendiri yang bisa baca/tulis lengkap
    match /users/{userId} {
      allow read, write: if isAdmin() || request.auth.uid == userId;
    }

    // Koleksi Rooms: Semua bisa baca, hanya Admin yang bisa tulis
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Koleksi Bookings: Semua bisa baca (untuk kalender), tapi update/delete sangat dibatasi
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && !isViewOnly();
      
      // Update/Delete: Admin & Asman bisa, Staff Umum bisa (untuk kelola konsumsi), User hanya bisa miliknya sendiri
      allow update: if isAdmin() || isAsman() || isStaffUmum() || (
        request.auth.uid == resource.data.userId && 
        !isViewOnly()
      );
      allow delete: if isAdmin() || (request.auth.uid == resource.data.userId && !isViewOnly());
    }

    // Koleksi Vehicle Bookings: PRIVASI KETAT
    match /vehicle_bookings/{bookingId} {
      allow read: if request.auth != null && (
        isAdmin() || isKoordinatorDriver() || isStaffUmum() || isAsman() || request.auth.uid == resource.data.userId
      );
      allow create: if request.auth != null && !isViewOnly();
      allow update: if request.auth != null && (
        isAdmin() || isKoordinatorDriver() || isAsman() || (
          request.auth.uid == resource.data.userId && 
          !isViewOnly() && 
          request.resource.data.status == resource.data.status // User tidak boleh ubah status sendiri
        )
      );
      allow delete: if request.auth != null && (
        isAdmin() || isKoordinatorDriver() || isAsman() || (
          request.auth.uid == resource.data.userId && 
          !isViewOnly() && 
          resource.data.status == 'pending' // Hanya boleh hapus jika masih pending
        )
      );
    }

    // Koleksi Item Requests: PRIVASI KETAT
    match /item_requests/{requestId} {
      allow read: if request.auth != null && (
        isAdmin() || isAsman() || isStaffUmum() || request.auth.uid == resource.data.userId
      );
      allow create: if request.auth != null && !isViewOnly();
      allow update: if request.auth != null && (
        isAdmin() || isAsman() || isStaffUmum() || (
          request.auth.uid == resource.data.userId && 
          resource.data.status == 'pending' &&
          request.resource.data.status == resource.data.status // User tidak boleh ubah status sendiri
        )
      );
      allow delete: if request.auth != null && (
        isAdmin() || (request.auth.uid == resource.data.userId && resource.data.status == 'pending')
      );
    }

    // Koleksi Maintenance Requests: PRIVASI KETAT
    match /maintenance_requests/{requestId} {
      allow read: if request.auth != null && (
        isAdmin() || isAsman() || isStaffUmum() || request.auth.uid == resource.data.userId
      );
      allow create: if request.auth != null && !isViewOnly();
      allow update: if request.auth != null && (
        isAdmin() || isStaffUmum() || (
          request.auth.uid == resource.data.userId && 
          resource.data.status == 'pending' &&
          request.resource.data.status == resource.data.status // User tidak boleh ubah status sendiri
        )
      );
      allow delete: if request.auth != null && (
        isAdmin() || (request.auth.uid == resource.data.userId && resource.data.status == 'pending')
      );
    }

    // Koleksi Driver Rates: Admin dan Koordinator Driver bisa baca tulis
    match /driver_rates/{rateId} {
      allow read, write: if isAdmin() || isKoordinatorDriver();
    }

    // Koleksi Drivers: Admin dan Koordinator Driver bisa baca tulis, yang lain bisa baca
    match /drivers/{driverId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isKoordinatorDriver() || 
                    (request.auth != null && request.auth.token.email.lower() == resource.data.email.lower());
    }

    // Koleksi Driver Trips: Admin dan Koordinator Driver bisa baca tulis, Driver terkait juga bisa baca
    match /driver_trips/{tripId} {
      allow read: if isAdmin() || isKoordinatorDriver() || isAsman() || (
        isDriverRole() && (
          request.auth.uid == resource.data.driverUid || 
          request.auth.token.email.lower() == resource.data.driverEmail.lower()
        )
      );
      allow update: if isAdmin() || isKoordinatorDriver() || isAsman() || (
        isDriverRole() && (
          request.auth.uid == resource.data.driverUid || 
          request.auth.token.email.lower() == resource.data.driverEmail.lower()
        )
      );
      allow write: if isAdmin() || isKoordinatorDriver() || isAsman();
    }

    // Koleksi Fleet Vehicles: Admin dan Koordinator Driver bisa baca tulis, yang lain bisa baca
    match /fleet_vehicles/{vehicleId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isKoordinatorDriver();
    }
  }
}
